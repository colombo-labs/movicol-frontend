    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^4.2.0",
    "react-router-dom": "^6.23.0",
    "socket.io-client": "^4.7.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/react": "^15.0.0",
    "@types/leaflet": "^1.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
